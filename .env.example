# ─────────────────────────────────────────────────────────────────────────────
# AutoBlogspot — Environment Configuration
# Copy to .env and fill in your values.
#
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ─── REQUIRED — change before deploy ─────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-with-python-secrets

# ─── App mode ─────────────────────────────────────────────────────────────────
DEBUG=false
BASE_URL=https://autoblogspot.com

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# In docker-compose, hostname is "postgres" (the service name).
# For local dev outside Docker: use localhost instead.
DATABASE_URL=postgresql://autoblogspot:your-db-password@postgres:5432/autoblogspot
POSTGRES_PASSWORD=your-db-password

# ─── Server (run.py only; production uses gunicorn.conf.py) ──────────────────
HOST=0.0.0.0
PORT=8000

# ─── Google Integrations ─────────────────────────────────────────────────────
# Google Analytics 4: lấy Measurement ID từ analytics.google.com → Admin → Data Streams
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# Google Search Console: lấy verification code từ GSC → Settings → Ownership Verification → HTML tag
# Chỉ lấy phần content="...", ví dụ: abc123xyz
GOOGLE_SITE_VERIFICATION=

# ─── Email / SMTP (required for password reset) ───────────────────────────────
# Gmail: enable "App Passwords" in Google Account → Security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AutoBlogspot <noreply@autoblogspot.com>
SMTP_TLS=true

# ─── Payment: SePay (VietQR / bank transfer) ─────────────────────────────────
# Configure in Admin → Settings after first login.
# These are stored in the database (app_settings table), not in .env.
# But for reference, the keys used in Admin Settings are:
#
#   payment_bank_name       = Tên ngân hàng (vd: MB, VCB, TCB...)
#   payment_account_number  = Số tài khoản
#   payment_account_holder  = Tên chủ tài khoản
#   payment_transfer_note   = Tiền tố nội dung CK (mặc định: ABLOG)
#   sepay_api_key           = API key từ app.sepay.vn (để tra cứu GD)
#
# IMPORTANT: Set sepay_webhook_token in Admin Settings.
# Dùng để xác thực webhook URL: /billing/webhook/sepay?token=YOUR_TOKEN
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ─── Payment: LemonSqueezy (international cards) ─────────────────────────────
# Configure in Admin → Settings after first login.
# Keys used in Admin Settings:
#
#   ls_api_key              = API key từ LemonSqueezy dashboard
#   ls_store_id             = Store ID
#   ls_pro_variant_id       = Variant ID của gói Pro
#   ls_business_variant_id  = Variant ID của gói Business
#   ls_webhook_secret       = Signing secret từ LemonSqueezy → Webhooks
#   ls_pro_price            = Giá hiển thị Pro (vd: $8/month)
#   ls_business_price       = Giá hiển thị Business (vd: $20/month)
#
# IMPORTANT: ls_webhook_secret là bắt buộc — webhook sẽ bị từ chối nếu thiếu.
# Lấy từ: LemonSqueezy Dashboard → Settings → Webhooks → Signing secret
